---
import yaml from "js-yaml";
import { readFileSync } from "node:fs";
import { resolve } from "node:path";
import LandscapeGrid from "../components/LandscapeGrid.astro";
import FilterBar from "../components/FilterBar.astro";
import ProblemSearch from "../components/ProblemSearch.astro";

const landscapePath = resolve(process.cwd(), "../data/landscape.yaml");
const landscape = yaml.load(readFileSync(landscapePath, "utf8")) as any;

const totalEntries = landscape.entries.length;
const totalCategories = landscape.categories.length;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>CSA AI Security Landscape</title>
    <meta
      name="description"
      content="Vendor-neutral market map for AI security and observability — Cloud Security Alliance"
    />
    <style>
      *,
      *::before,
      *::after {
        box-sizing: border-box;
        margin: 0;
        padding: 0;
      }
      body {
        font-family: system-ui, -apple-system, sans-serif;
        background: #0a0f1a;
        color: #e0e0e0;
        min-height: 100vh;
      }
      header {
        display: flex;
        align-items: center;
        padding: 0 20px;
        background: #0d1520;
        border-bottom: 1px solid #1a2a3a;
        position: sticky;
        top: 0;
        z-index: 10;
        height: 52px;
        gap: 20px;
      }
      .brand {
        display: flex;
        flex-direction: column;
        gap: 1px;
        flex-shrink: 0;
      }
      .site-title {
        font-size: 14px;
        color: #7eb8f7;
        font-weight: 700;
        letter-spacing: 0.3px;
      }
      .site-subtitle {
        font-size: 10px;
        color: #445566;
      }
      .header-right {
        display: flex;
        align-items: center;
        gap: 14px;
        flex: 1;
        justify-content: flex-end;
        min-width: 0;
      }
      .meta-stat {
        font-size: 10px;
        color: #445;
        white-space: nowrap;
        flex-shrink: 0;
      }
      .meta-stat strong {
        color: #7eb8f7;
      }
    </style>
  </head>
  <body>
    <header>
      <div class="brand">
        <span class="site-title">CSA AI Security Landscape</span>
        <span class="site-subtitle"
          >Vendor-neutral market map for AI security and observability</span
        >
      </div>
      <div class="header-right">
        <span class="meta-stat"
          ><strong>{totalEntries}</strong> tools &middot; <strong
            >{totalCategories}</strong
          > categories</span
        >
        <ProblemSearch />
      </div>
    </header>
    <FilterBar categories={landscape.categories} />
    <LandscapeGrid landscape={landscape} />
  </body>
</html>
