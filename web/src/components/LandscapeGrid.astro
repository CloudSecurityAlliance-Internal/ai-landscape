---
import EntryTile from "./EntryTile.astro";

interface Entry {
  id: string;
  name: string;
  category: string;
  description: string;
  website: string;
  logo?: string;
  organization: string;
  pricing: string;
  license: string;
  api_available?: boolean;
  vendor_type?: string;
  csa_member?: boolean;
  tags?: string[];
  capability_tags?: string[];
  integrations?: string[];
  buyer_problems?: string[];
  maestro_layers?: string[];
  aicm_control_families?: string[];
  review?: { status?: string; last_reviewed?: string | null; reviewed_by?: string | null };
  added: string;
}

interface Category {
  id: string;
  name: string;
  area: string;
  description?: string;
}

interface Props {
  landscape: { categories: Category[]; entries: Entry[] };
}

const { landscape } = Astro.props;

const AREAS = [
  {
    id: "security-for-ai",
    label: "Security for AI",
    description:
      "Capabilities that protect AI systems from attack, manipulation, and abuse.",
  },
  {
    id: "ai-for-security",
    label: "AI for Security",
    description: "Capabilities that use AI to power security operations.",
  },
  {
    id: "ai-governance-risk",
    label: "AI Governance, Observability & Risk",
    description:
      "Capabilities providing visibility, control, and accountability over AI.",
  },
];

const byCategory = Object.fromEntries(
  landscape.categories.map((cat) => [
    cat.id,
    landscape.entries.filter((e) => e.category === cat.id),
  ])
);

const categoriesByArea = Object.fromEntries(
  AREAS.map((area) => [
    area.id,
    landscape.categories.filter((cat) => cat.area === area.id),
  ])
);
---

<main class="landscape">
  {
    AREAS.map((area) => (
      <section class="area-section" data-area={area.id}>
        <div class="area-header">
          <h2 class="area-title">{area.label}</h2>
          <span class="area-desc">{area.description}</span>
        </div>
        <div class="categories-row">
          {(categoriesByArea[area.id] ?? []).map((cat) => (
            <section
              class="category-section"
              data-category={cat.id}
              data-area={area.id}
            >
              <h3 class="category-header">
                {cat.name}
                <span class="count">{byCategory[cat.id]?.length ?? 0}</span>
              </h3>
              {cat.description && (
                <p class="category-desc">{cat.description}</p>
              )}
              <div class="tile-grid">
                {(byCategory[cat.id] ?? []).map((entry) => (
                  <EntryTile entry={entry} />
                ))}
              </div>
            </section>
          ))}
        </div>
      </section>
    ))
  }
  <div id="empty-state" class="empty-state" hidden>
    <p class="empty-msg">No entries match the current filters.</p>
    <p class="empty-hint">Try broadening your search or resetting the area and category filters above.</p>
  </div>
  <div id="empty-state-csa" class="empty-state" hidden>
    <p class="empty-msg">No verified CSA member entries yet.</p>
    <p class="empty-hint">CSA member status must be confirmed against the CSA member roster before publication.</p>
  </div>
</main>

<style>
  .landscape {
    padding: 16px 20px;
  }
  .area-section {
    margin-bottom: 32px;
  }
  .area-header {
    display: flex;
    align-items: baseline;
    gap: 12px;
    margin-bottom: 12px;
    padding-bottom: 8px;
    border-bottom: 2px solid #005b99;
  }
  .area-title {
    font-size: 13px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 1.5px;
    color: #005b99;
    white-space: nowrap;
  }
  .area-desc {
    font-size: 11px;
    color: #57606a;
  }
  .categories-row {
    display: flex;
    flex-wrap: wrap;
    gap: 20px;
    align-items: flex-start;
  }
  .category-section {
    flex: 0 0 auto;
    min-width: 180px;
  }
  .category-header {
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 0.8px;
    text-transform: uppercase;
    color: #1a78c2;
    margin-bottom: 4px;
    display: flex;
    align-items: center;
    gap: 6px;
  }
  .count {
    font-size: 9px;
    background: #dbeafe;
    color: #1e40af;
    padding: 1px 5px;
    border-radius: 8px;
    font-weight: normal;
    letter-spacing: 0;
  }
  .category-desc {
    font-size: 10px;
    color: #57606a;
    margin-bottom: 6px;
    max-width: 360px;
    line-height: 1.4;
  }
  .tile-grid {
    display: flex;
    flex-wrap: wrap;
    gap: 4px;
  }
  .empty-state {
    margin: 40px auto;
    text-align: center;
    max-width: 480px;
    padding: 0 20px;
  }
  .empty-msg {
    font-size: 13px;
    color: #005b99;
    margin-bottom: 8px;
    font-weight: 600;
  }
  .empty-hint {
    font-size: 11px;
    color: #57606a;
    line-height: 1.5;
  }
</style>
