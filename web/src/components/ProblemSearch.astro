---
// No props — pure client-side search component
---

<div class="problem-search">
  <input
    type="search"
    id="problem-input"
    class="problem-input"
    placeholder="Search by problem, tool, or keyword…"
    autocomplete="off"
    spellcheck="false"
  />
  <span id="problem-count" class="problem-count"></span>
</div>

<style>
  .problem-search {
    display: flex;
    align-items: center;
    gap: 8px;
    flex: 1;
    min-width: 0;
  }
  .problem-input {
    flex: 1;
    min-width: 160px;
    max-width: 320px;
    padding: 4px 10px;
    background: #ffffff;
    border: 1px solid #d0d7de;
    border-radius: 4px;
    color: #1f2328;
    font-size: 12px;
    outline: none;
  }
  .problem-input:focus {
    border-color: #005b99;
    color: #1f2328;
  }
  .problem-input::placeholder {
    color: #9ca3af;
  }
  .problem-count {
    font-size: 11px;
    color: #005b99;
    white-space: nowrap;
    transition: color 0.15s;
  }
  .problem-count[data-empty="true"] {
    color: #dc2626;
  }
</style>

<script>
  const input = document.getElementById("problem-input") as HTMLInputElement;

  input?.addEventListener("input", () => {
    if (typeof (window as any).__applyFilters === "function") {
      (window as any).__applyFilters();
    }
  });
</script>
