---
interface Category {
  id: string;
  name: string;
  area?: string;
}

interface Props {
  categories: Category[];
}

const { categories } = Astro.props;

const AREAS = [
  { id: "all", label: "All Areas" },
  { id: "security-for-ai", label: "Security for AI" },
  { id: "ai-for-security", label: "AI for Security" },
  { id: "ai-governance-risk", label: "Governance/Risk" },
];
---

<nav class="filter-bar">
  <div class="filter-group">
    {
      AREAS.map((area, i) => (
        <button
          class:list={["filter-btn", "area-btn", i === 0 && "active"]}
          data-area={area.id}
        >
          {area.label}
        </button>
      ))
    }
  </div>
  <div class="filter-sep"></div>
  <select class="cat-select" id="cat-select">
    <option value="all">All Categories</option>
    {
      categories.map((cat) => (
        <option value={cat.id} data-cat-area={cat.area ?? ""}>
          {cat.name}
        </option>
      ))
    }
  </select>
  <div class="filter-sep"></div>
  <label class="csa-toggle">
    <input type="checkbox" id="csa-only" />
    <span>CSA Members only</span>
  </label>
  <div class="filter-sep"></div>
  <button class="about-btn" id="about-btn" title="How to use this map">?</button>
</nav>

<div id="info-panel" class="info-panel" hidden>
  <div class="info-grid">
    <div class="info-item">
      <span class="info-label">Primary category</span>
      <span class="info-text">Each vendor's column placement — their main market segment within the landscape.</span>
    </div>
    <div class="info-item">
      <span class="info-label">Ancillary tags</span>
      <span class="info-text">Purple chips on each tile — cross-cutting capabilities beyond the primary category. A vendor can appear in multiple capability contexts without being miscategorized.</span>
    </div>
    <div class="info-item">
      <span class="info-label">Problem search</span>
      <span class="info-text">Describe your security problem in plain language. Matches vendor descriptions, tags, and buyer problems — no category vocabulary required.</span>
    </div>
    <div class="info-item">
      <span class="info-label">AICM / MAESTRO mappings</span>
      <span class="info-text">Each vendor is mapped to CSA AI Controls Matrix (AICM) control families and MAESTRO AI stack layers. These mappings are part of the vendor metadata and searchable by code — e.g. <code>IAM</code>, <code>SC</code>, <code>L3-agent-frameworks</code>.</span>
    </div>
    <div class="info-item">
      <span class="info-label">Integrations</span>
      <span class="info-text">Ecosystem mapping — platforms and tools each vendor supports. Search by platform name (e.g. <code>Splunk</code>, <code>AWS</code>) to find vendors that fit your stack.</span>
    </div>
  </div>
</div>

<style>
  .filter-bar {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 6px 20px;
    background: #ffffff;
    border-bottom: 1px solid #d0d7de;
    position: sticky;
    top: 52px;
    z-index: 9;
    flex-wrap: nowrap;
  }
  .filter-group {
    display: flex;
    gap: 3px;
    flex-shrink: 0;
  }
  .filter-sep {
    width: 1px;
    height: 20px;
    background: #d0d7de;
    flex-shrink: 0;
    margin: 0 2px;
  }
  .filter-btn {
    padding: 3px 9px;
    border-radius: 4px;
    border: 1px solid #d0d7de;
    background: transparent;
    color: #57606a;
    cursor: pointer;
    white-space: nowrap;
    font-size: 11px;
  }
  .filter-btn:hover {
    background: #f0f6fc;
    color: #005b99;
    border-color: #005b99;
  }
  .filter-btn.active,
  .area-btn.active {
    background: #005b99;
    color: #ffffff;
    border-color: #005b99;
  }
  .cat-select {
    padding: 3px 8px;
    border-radius: 4px;
    border: 1px solid #d0d7de;
    background: #ffffff;
    color: #1f2328;
    font-size: 11px;
    cursor: pointer;
    outline: none;
    min-width: 160px;
    flex-shrink: 0;
  }
  .cat-select:focus {
    border-color: #005b99;
    color: #1f2328;
  }
  .csa-toggle {
    display: flex;
    align-items: center;
    gap: 5px;
    font-size: 11px;
    color: #005b99;
    cursor: pointer;
    white-space: nowrap;
    flex-shrink: 0;
    user-select: none;
  }
  .csa-toggle input {
    accent-color: #005b99;
    cursor: pointer;
  }
  .about-btn {
    padding: 3px 8px;
    border-radius: 4px;
    border: 1px solid #d0d7de;
    background: transparent;
    color: #57606a;
    cursor: pointer;
    font-size: 12px;
    font-weight: 700;
    flex-shrink: 0;
    line-height: 1;
  }
  .about-btn:hover,
  .about-btn.active {
    background: #005b99;
    color: #ffffff;
    border-color: #005b99;
  }
  .info-panel {
    background: #f0f6fc;
    border-bottom: 1px solid #d0d7de;
    padding: 10px 20px;
  }
  .info-grid {
    display: flex;
    flex-wrap: wrap;
    gap: 10px 24px;
  }
  .info-item {
    display: flex;
    gap: 6px;
    align-items: baseline;
    font-size: 11px;
    flex: 1 1 220px;
    max-width: 480px;
  }
  .info-label {
    color: #005b99;
    font-weight: 700;
    white-space: nowrap;
    flex-shrink: 0;
  }
  .info-text {
    color: #57606a;
    line-height: 1.4;
  }
  .info-text code {
    background: #dbeafe;
    color: #1e40af;
    padding: 0 3px;
    border-radius: 2px;
    font-size: 10px;
    font-family: ui-monospace, 'SFMono-Regular', Consolas, monospace;
  }
</style>

<script>
  type HTMLBtn = HTMLButtonElement;

  let activeArea = "all";
  let activeCategory = "all";
  let csaOnly = false;

  function applyFilters() {
    const query =
      (
        document.getElementById("problem-input") as HTMLInputElement
      )?.value
        .trim()
        .toLowerCase() ?? "";

    const tiles = document.querySelectorAll<HTMLElement>(".entry-tile");
    const totalTiles = tiles.length;
    let visibleCount = 0;

    tiles.forEach((tile) => {
      const section = tile.closest<HTMLElement>(".category-section");
      const tileArea = section?.getAttribute("data-area") ?? "";
      const tileCat = section?.getAttribute("data-category") ?? "";

      const areaMatch = activeArea === "all" || tileArea === activeArea;
      const catMatch = activeCategory === "all" || tileCat === activeCategory;
      const csaMatch = !csaOnly || tile.querySelector(".csa-badge") !== null;
      const searchMatch =
        !query || (tile.getAttribute("data-search") ?? "").includes(query);

      const show = areaMatch && catMatch && csaMatch && searchMatch;
      tile.style.display = show ? "" : "none";
      if (show) visibleCount++;
    });

    // Cascade: hide category sections with no visible tiles
    document.querySelectorAll<HTMLElement>(".category-section").forEach((sec) => {
      const anyVisible = [
        ...sec.querySelectorAll<HTMLElement>(".entry-tile"),
      ].some((t) => t.style.display !== "none");
      sec.style.display = anyVisible ? "" : "none";
    });

    // Cascade: hide area sections with no visible categories
    document.querySelectorAll<HTMLElement>(".area-section").forEach((sec) => {
      const anyVisible = [
        ...sec.querySelectorAll<HTMLElement>(".category-section"),
      ].some((c) => c.style.display !== "none");
      sec.style.display = anyVisible ? "" : "none";
    });

    // Update result count — show whenever any filter is active
    const anyFilterActive =
      activeArea !== "all" || activeCategory !== "all" || csaOnly || !!query;
    const countEl = document.getElementById("problem-count");
    if (countEl) {
      if (anyFilterActive) {
        countEl.textContent = `${visibleCount} of ${totalTiles} match`;
        countEl.setAttribute("data-empty", visibleCount === 0 ? "true" : "false");
      } else {
        countEl.textContent = "";
        countEl.removeAttribute("data-empty");
      }
    }

    // Show appropriate empty state when no entries match
    const emptyEl = document.getElementById("empty-state") as HTMLElement | null;
    const emptyCSAEl = document.getElementById("empty-state-csa") as HTMLElement | null;
    if (emptyEl && emptyCSAEl) {
      if (visibleCount === 0) {
        emptyEl.hidden = csaOnly;
        emptyCSAEl.hidden = !csaOnly;
      } else {
        emptyEl.hidden = true;
        emptyCSAEl.hidden = true;
      }
    }
  }

  // Expose for ProblemSearch to call
  (window as any).__applyFilters = applyFilters;

  // Area buttons
  document.querySelectorAll<HTMLBtn>(".area-btn").forEach((btn) => {
    btn.addEventListener("click", () => {
      document
        .querySelectorAll<HTMLBtn>(".area-btn")
        .forEach((b) => b.classList.remove("active"));
      btn.classList.add("active");
      activeArea = btn.getAttribute("data-area") ?? "all";
      // Reset category when switching area
      activeCategory = "all";
      const sel = document.getElementById("cat-select") as HTMLSelectElement;
      if (sel) sel.value = "all";
      applyFilters();
    });
  });

  // Category dropdown
  const catSelect = document.getElementById("cat-select") as HTMLSelectElement;
  catSelect?.addEventListener("change", () => {
    activeCategory = catSelect.value;
    applyFilters();
  });

  // CSA toggle
  const csaCheckbox = document.getElementById("csa-only") as HTMLInputElement;
  csaCheckbox?.addEventListener("change", () => {
    csaOnly = csaCheckbox.checked;
    applyFilters();
  });

  // About panel toggle
  const aboutBtn = document.getElementById("about-btn") as HTMLButtonElement;
  const infoPanel = document.getElementById("info-panel") as HTMLElement;
  aboutBtn?.addEventListener("click", () => {
    infoPanel.hidden = !infoPanel.hidden;
    aboutBtn.classList.toggle("active", !infoPanel.hidden);
    aboutBtn.textContent = infoPanel.hidden ? "?" : "✕";
    aboutBtn.title = infoPanel.hidden ? "How to use this map" : "Close";
  });
</script>
